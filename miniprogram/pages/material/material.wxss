.container {
  min-height: 100vh;
  background: #F5F7FA;
}

.tabs-wrapper {
  background: #FFFFFF;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.tabs-scroll {
  width: 100%;
}

.tabs-list {
  display: flex;
  padding: 0 20rpx;
  white-space: nowrap;
}

.tab-item {
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  background: #F8F9FA;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-item.active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.type-tabs {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.type-pill-wrapper {
  display: flex;
  background: #F2F3F5;
  border-radius: 50rpx;
  padding: 6rpx;
  gap: 4rpx;
}

.type-pill {
  display: flex;
  align-items: center;
  padding: 16rpx 40rpx;
  border-radius: 44rpx;
  transition: all 0.25s ease;
}

.type-pill:active {
  transform: scale(0.95);
}

.type-pill.active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.pill-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.pill-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.type-pill.active .pill-text {
  color: #FFFFFF;
  font-weight: 600;
}

.type-count {
  font-size: 22rpx;
  color: #AAAAAA;
  background: #F8F9FA;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  margin: 20rpx 30rpx;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.search-bar:focus-within {
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.2);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.content-section {
  padding: 0 20rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.material-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.material-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.material-item:active {
  transform: scale(0.98);
}

.material-wrapper {
  position: relative;
  width: 100%;
  padding-top: 100%;
  background: #F8F9FA;
}

.material-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.material-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.material-name {
  display: block;
  padding: 16rpx 20rpx 8rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.material-category {
  display: block;
  padding: 0 20rpx 16rpx;
  font-size: 22rpx;
  color: #999999;
}

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.sticker-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.sticker-item:active {
  transform: scale(0.95);
}

.sticker-wrapper {
  width: 100%;
  padding-top: 100%;
  position: relative;
  margin-bottom: 12rpx;
}

.sticker-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.sticker-name {
  font-size: 22rpx;
  color: #666666;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}