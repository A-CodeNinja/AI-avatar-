<view class="container">
  <view class="info-bar">
    <view class="info-tag type-tag">{{typeText}}</view>
    <view class="info-center">
      <text class="info-style" wx:if="{{styleText}}">{{styleText}}</text>
      <text class="info-style" wx:if="{{ethnic && ethnic !== 'none'}}"> + 民族风</text>
    </view>
    <view class="info-tag success-tag">
      <image class="success-icon" src="/images/icons/check.svg" mode="aspectFit"></image>
      <text>成功</text>
    </view>
  </view>

  <view class="result-image-section">
    <view class="image-wrapper">
      <image wx:if="{{tempFilePath}}" class="result-image" src="{{tempFilePath}}" mode="aspectFit"></image>
      <view wx:else class="placeholder">
        <view class="loading-spinner"></view>
        <text class="loading-text">AI生成中...</text>
      </view>
    </view>
    <view class="saved-badge" wx:if="{{isSaved}}">
      <image class="saved-icon" src="/images/icons/check.svg" mode="aspectFit"></image>
      <text>已保存</text>
    </view>
  </view>

  <view class="frames-section">
    <view class="section-header">
      <text class="section-title">{{frameSectionTitle}}</text>
      <text class="section-tips">点击选择</text>
    </view>
    <scroll-view class="frames-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
      <view class="frames-list">
        <view 
          wx:for="{{frames}}" 
          wx:key="id"
          class="frame-item {{selectedFrame === item.path ? 'active' : ''}}"
          data-frame="{{item.path}}"
          bindtap="selectFrame"
        >
          <image class="frame-icon" src="{{item.path}}" mode="aspectFit"></image>
          <text class="frame-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="action-section">
    <view class="main-actions">
      <button class="action-btn btn-save" bindtap="saveImage">
        <image class="btn-icon" src="/images/icons/download.svg" mode="aspectFit"></image>
        <text>{{isSaved ? '已保存' : '保存相册'}}</text>
      </button>
      <button class="action-btn btn-share" open-type="share">
        <image class="btn-icon" src="/images/icons/share.svg" mode="aspectFit"></image>
        <text>分享小程序</text>
      </button>
    </view>
    <view class="sub-actions">
      <button 
        class="sub-btn {{isSharedToGallery ? 'sub-done' : ''}}" 
        bindtap="shareToGallery"
      >
        <image class="sub-btn-icon" src="/images/icons/gallery.svg" mode="aspectFit"></image>
        <text>{{isSharedToGallery ? '已分享到头像墙' : '分享到头像墙'}}</text>
      </button>
      <button class="sub-btn" bindtap="regenerate">
        <image class="sub-btn-icon" src="/images/icons/refresh.svg" mode="aspectFit"></image>
        <text>重新生成</text>
      </button>
    </view>
  </view>

  <view class="tips-row">
    <view class="tips-dot"></view>
    <text class="tips-text">AI生成内容仅供参考，请勿用于不当用途</text>
  </view>
</view>