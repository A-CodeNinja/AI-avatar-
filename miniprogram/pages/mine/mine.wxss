.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.user-header {
  background: linear-gradient(180deg, #667EEA 0%, #764BA2 100%);
  padding: 40rpx 30rpx 60rpx;
  position: relative;
}

.user-header::before {
  content: '';
  position: absolute;
  bottom: -100rpx;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #F5F7FA;
  border-radius: 50rpx 50rpx 0 0;
}

.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.user-left {
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.user-left:active {
  opacity: 0.8;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 20rpx;
  background: rgba(255,255,255,0.2);
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-right {
  display: flex;
  align-items: center;
}

.points-box {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(10rpx);
}

.points-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 6rpx;
}

.points-value {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx;
  flex: 1;
  transition: all 0.3s ease;
}

.stat-item:active {
  opacity: 0.7;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.3);
}

.stat-value {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.quick-actions {
  display: flex;
  background: #FFFFFF;
  margin: -30rpx 30rpx 24rpx;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.quick-item:active {
  transform: scale(0.95);
}

.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-icon {
  width: 44rpx;
  height: 44rpx;
}

.signin-bg { background: linear-gradient(135deg, #FFD93D 0%, #FF6B6B 100%); }
.invite-bg { background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%); }
.tools-bg  { background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%); }
.contact-bg { background: linear-gradient(135deg, #2196F3 0%, #03A9F4 100%); }

.quick-label {
  font-size: 24rpx;
  color: #1A1A1A;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.quick-sub {
  font-size: 20rpx;
  color: #FF6B6B;
}

.menu-section {
  margin: 0 30rpx;
}

.menu-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8F9FA;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-title {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
}

.menu-reward {
  font-size: 24rpx;
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
}

.version-info {
  text-align: center;
  padding: 40rpx 0;
}

.version-text {
  font-size: 22rpx;
  color: #CCCCCC;
}