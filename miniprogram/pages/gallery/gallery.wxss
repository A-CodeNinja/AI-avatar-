.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F4F7FF 0%, #FFFFFF 100%);
}

.gallery-banner {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.gallery-banner::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.banner-content {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.banner-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.6;
  position: relative;
  z-index: 1;
}

.tabs-wrapper {
  background: #FFFFFF;
  padding: 20rpx 0;
  box-shadow: 0 6rpx 22rpx rgba(15, 23, 42, 0.08);
  border-bottom: 1rpx solid #EEF2FF;
}

.tabs-scroll {
  width: 100%;
}

.tabs-list {
  display: flex;
  padding: 0 20rpx;
  white-space: nowrap;
}

.tab-item {
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  background: #F8FAFF;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #475569;
  flex-shrink: 0;
  transition: all 0.3s ease;
  border: 2rpx solid #E7EDFF;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-item.active {
  background: linear-gradient(135deg, #5C7CFA 0%, #4263EB 100%);
  color: #FFFFFF;
  font-weight: 500;
  border-color: #4C6EF5;
  box-shadow: 0 6rpx 14rpx rgba(66, 99, 235, 0.32);
}

.gallery-section {
  padding: 20rpx;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.gallery-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
  transition: all 0.3s ease;
}

.gallery-item:active {
  transform: translateY(-2rpx) scale(0.99);
}

.gallery-wrapper {
  position: relative;
  width: 100%;
  padding-top: 100%;
  background: #F8F9FA;
}

.gallery-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.gallery-overlay {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-icon {
  width: 28rpx;
  height: 28rpx;
}

.gallery-action-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  padding: 20rpx 16rpx 12rpx;
  display: flex;
  justify-content: flex-end;
}

.like-btn {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.like-btn.active {
  background: rgba(255, 107, 107, 0.9);
}

.like-btn:active {
  background: rgba(255,255,255,0.35);
}

.like-icon-sm {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

.like-num {
  font-size: 20rpx;
  color: #FFFFFF;
}

.gallery-info {
  padding: 16rpx 20rpx;
}

.gallery-name {
  display: block;
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #BBBBBB;
}

.share-section {
  position: fixed;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  bottom: calc(136rpx + constant(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
}

.share-btn {
  display: flex;
  align-items: center;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #4263EB 0%, #364FC7 100%);
  border-radius: 50rpx;
  box-shadow: 0 12rpx 30rpx rgba(54, 79, 199, 0.4);
  border: none;
  transition: all 0.3s ease;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  transform: scale(0.95);
}

.share-btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.share-btn-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}