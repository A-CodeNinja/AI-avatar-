<view class="container">
  <view class="gallery-banner">
    <view class="banner-content">
      <text class="banner-title">头像墙</text>
      <text class="banner-subtitle">发现好看的AI头像</text>
    </view>
    <image class="banner-icon" src="/images/icons/sparkle.svg" mode="aspectFit"></image>
  </view>

  <view class="tabs-wrapper">
    <scroll-view class="tabs-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
      <view class="tabs-list">
        <view 
          wx:for="{{categoryTabs}}" 
          wx:key="id"
          class="tab-item {{currentCategory === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="switchCategory"
        >
          <text class="tab-text">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="gallery-section">
    <view class="gallery-grid">
      <view 
        wx:for="{{filteredImages}}" 
        wx:key="id"
        class="gallery-item"
        data-url="{{item.url}}"
        bindtap="previewImage"
      >
        <view class="gallery-wrapper">
          <image class="gallery-image" src="{{item.url}}" mode="aspectFill" lazy-load></image>
          <view class="gallery-overlay" wx:if="{{item.isShared}}">
            <image class="share-icon" src="/images/icons/shared.png"></image>
          </view>
          <view class="gallery-action-bar">
            <view class="like-btn {{item.isLiked ? 'active' : ''}}" wx:if="{{item.isShared}}" data-id="{{item.id}}" catchtap="handleLike">
              <image class="like-icon-sm" src="/images/icons/like.png"></image>
              <text class="like-num">{{item.likes || 0}}</text>
            </view>
          </view>
        </view>
        <view class="gallery-info">
          <text class="gallery-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{filteredImages.length === 0}}" class="empty-state">
      <image class="empty-icon" src="/images/empty.png"></image>
      <text class="empty-text">暂无该分类的头像</text>
      <text class="empty-sub">快去生成一个吧</text>
    </view>
  </view>

  <view class="share-section" wx:if="{{currentCategory === 'shared'}}">
    <button class="share-btn" open-type="share">
      <image class="share-btn-icon" src="/images/icons/share.svg"></image>
      <text class="share-btn-text">分享我的作品</text>
    </button>
  </view>
</view>