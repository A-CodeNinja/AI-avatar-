.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.08);
  padding: 30rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.desc {
  display: block;
  margin-top: 10rpx;
  margin-bottom: 20rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.content-input {
  width: 100%;
  height: 260rpx;
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.contact-input {
  margin-top: 18rpx;
  width: 100%;
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.submit-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #4f46e5 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-btn::after {
  border: none;
}
