<view class="container">
  <view class="header-section">
    <view class="points-card">
      <view class="points-top">
        <view class="points-info">
          <text class="points-label">我的积分</text>
          <view class="points-row">
            <text class="points-value">{{points}}</text>
            <view class="points-btn" bindtap="goToPoints">
              <image class="points-btn-icon" src="/images/icons/plus.svg" mode="aspectFit"></image>
            </view>
          </view>
        </view>
        <image class="header-decoration" src="/images/icons/sparkle.svg" mode="aspectFit"></image>
      </view>
      <view class="points-bottom">
        <view class="points-item" bindtap="goToPoints">
          <image class="points-item-icon" src="/images/icons/calendar.svg" mode="aspectFit"></image>
          <text class="points-item-text">每日签到</text>
        </view>
        <view class="points-item" bindtap="watchAd">
          <image class="points-item-icon" src="/images/icons/star.svg" mode="aspectFit"></image>
          <text class="points-item-text">看广告领积分</text>
        </view>
        <view class="points-item" bindtap="goToInvite">
          <image class="points-item-icon" src="/images/icons/invite.png" mode="aspectFit"></image>
          <text class="points-item-text">邀请好友</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card section-card-elevated">
    <view class="section-header">
      <text class="section-title">上传照片</text>
      <text class="section-tips">支持自拍或相册</text>
    </view>
    <view class="upload-area" bindtap="chooseImage">
      <image wx:if="{{selectedImage}}" class="preview-image" src="{{selectedImage}}" mode="aspectFill"></image>
      <view wx:else class="upload-placeholder">
        <view class="upload-icon-wrapper">
          <image class="upload-icon-img" src="/images/icons/camera.svg" mode="aspectFit"></image>
        </view>
        <text class="upload-text">点击选择照片</text>
        <text class="upload-tips">支持jpg、png格式</text>
      </view>
    </view>
  </view>

  <view class="section-card section-card-elevated">
    <view class="section-header">
      <text class="section-title">民族风格</text>
      <text class="section-tips">特色风格</text>
    </view>
    <scroll-view class="ethnic-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
      <view class="ethnic-list">
        <view
          wx:for="{{ethnicStyles}}"
          wx:key="key"
          class="ethnic-item {{selectedEthnic === item.key ? 'active' : ''}}"
          data-ethnic="{{item.key}}"
          bindtap="selectEthnic"
        >
          <image class="ethnic-icon" src="{{item.icon}}" mode="aspectFill"
            style="border: 4rpx solid {{selectedEthnic === item.key ? item.color : 'transparent'}}; background: {{item.color}}20"></image>
          <text class="ethnic-name">{{item.name}}</text>
          <text class="ethnic-desc">{{item.desc}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section-card section-card-elevated">
    <view class="section-header">
      <text class="section-title">基础风格</text>
      <text class="section-tips">AI智能生成</text>
    </view>
    <scroll-view class="style-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
      <view class="style-list">
        <view
          wx:for="{{styles}}"
          wx:key="key"
          class="style-item {{selectedStyle === item.key ? 'active' : ''}}"
          data-style="{{item.key}}"
          bindtap="selectStyle"
        >
          <image class="style-icon-img" src="/images/styles/{{item.key}}.png" mode="aspectFill"></image>
          <text class="style-name">{{item.name}}</text>
          <text wx:if="{{item.hot}}" class="style-hot">HOT</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="selection-bar">
    <text class="selection-text">已选风格：{{selectedStyle}}</text>
    <text class="selection-text" wx:if="{{selectedEthnic}}">民族加成：{{selectedEthnic}}</text>
    <text class="selection-text" wx:else>民族加成：无</text>
  </view>

  <view class="action-section">
    <button
      class="generate-btn"
      bindtap="generateAvatar"
      disabled="{{isGenerating || !selectedImage}}"
    >
      <view class="btn-content">
        <image wx:if="{{!isGenerating}}" class="btn-icon" src="/images/icons/sparkle.svg" mode="aspectFit"></image>
        <view wx:else class="btn-loading-icon"></view>
        <text class="btn-text">{{isGenerating ? '生成中...' : '立即生成AI头像'}}</text>
      </view>
      <text class="btn-points">消耗10积分</text>
    </button>
  </view>

  <view class="tips-section">
    <view class="tips-item">
      <image class="tips-icon" src="/images/icons/check.svg" mode="aspectFit"></image>
      <text class="tips-text">AI智能生成，效果自然</text>
    </view>
    <view class="tips-item">
      <image class="tips-icon" src="/images/icons/check.svg" mode="aspectFit"></image>
      <text class="tips-text">支持5种民族风格</text>
    </view>
    <view class="tips-item">
      <image class="tips-icon" src="/images/icons/check.svg" mode="aspectFit"></image>
      <text class="tips-text">生成内容仅供参考</text>
    </view>
  </view>

  <view class="safe-bottom-space"></view>
</view>