.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F7FA 0%, #FFFFFF 100%);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
}

.header-section {
  padding: 20rpx 30rpx;
}

.points-card {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  position: relative;
  overflow: hidden;
}

.points-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
  border-radius: 50%;
}

.points-card::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.points-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.points-info {
  flex: 1;
}

.points-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.points-row {
  display: flex;
  align-items: center;
}

.points-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.points-btn {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  transition: all 0.2s ease;
}

.points-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.35);
}

.points-btn-icon {
  width: 28rpx;
  height: 28rpx;
}

.header-decoration {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.6;
}

.points-bottom {
  display: flex;
  justify-content: space-around;
  position: relative;
  z-index: 1;
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.points-item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.25);
}

.points-item-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
}

.points-item-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.section-card {
  background: #FFFFFF;
  margin: 0 30rpx 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-card-elevated {
  border: 2rpx solid #EFF3FF;
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.section-tips {
  font-size: 22rpx;
  color: #999999;
}

.section-more {
  font-size: 24rpx;
  color: #667EEA;
}

.upload-area {
  width: 100%;
  height: 520rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #F8F9FA 0%, #F0F2F5 100%);
  border: 3rpx dashed #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.upload-area:active {
  border-color: #667EEA;
  background: linear-gradient(135deg, #F0F4FF 0%, #E8EEFF 100%);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon-wrapper {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.upload-icon-img {
  width: 60rpx;
  height: 60rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.upload-tips {
  font-size: 22rpx;
  color: #999999;
}

.ethnic-scroll {
  width: 100%;
}

.ethnic-list {
  display: flex;
  padding-right: 10rpx;
}

.ethnic-item {
  flex-shrink: 0;
  margin-right: 20rpx;
  width: 160rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: #F8F9FA;
  border: 3rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.ethnic-item.active {
  background: linear-gradient(135deg, rgba(102,126,234,0.12) 0%, rgba(118,75,162,0.12) 100%);
  border-color: #667EEA;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.ethnic-item:active {
  transform: scale(0.95);
}

.ethnic-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  overflow: hidden;
}

.ethnic-name {
  font-size: 22rpx;
  color: #333333;
  font-weight: 600;
  text-align: center;
  margin-bottom: 4rpx;
}

.ethnic-desc {
  font-size: 18rpx;
  color: #999999;
  text-align: center;
}

.ethnic-item.active .ethnic-name {
  color: #667EEA;
}

.style-scroll {
  width: 100%;
}

.style-list {
  display: flex;
  padding-right: 10rpx;
}

.style-item {
  flex-shrink: 0;
  margin-right: 20rpx;
  width: 150rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.3s ease;
}

.style-item.active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-color: #667EEA;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.style-item:active {
  transform: scale(0.95);
}

.style-icon-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: #E0E0E0;
}

.style-name {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.style-item.active .style-name {
  color: #FFFFFF;
}

.style-hot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #FFFFFF;
  font-size: 16rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.selection-bar {
  margin: 0 30rpx 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #F8FAFF 100%);
  border: 2rpx solid #DDE6FF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.selection-text {
  font-size: 22rpx;
  color: #3E63DD;
  max-width: 48%;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.action-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.generate-btn {
  width: 100%;
  height: 110rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  margin-bottom: 20rpx;
  line-height: normal;
  transition: all 0.3s ease;
}

.generate-btn::after {
  border: none;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.generate-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
  background: linear-gradient(135deg, #BFC9F8 0%, #B7A9DF 100%);
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.btn-loading-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

.btn-points {
  font-size: 22rpx;
  opacity: 0.85;
  font-weight: normal;
  margin-top: 4rpx;
}

.tips-section {
  margin: 0 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFF 100%);
  border-radius: 16rpx;
  border-left: 6rpx solid #667EEA;
}

.tips-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #666666;
}